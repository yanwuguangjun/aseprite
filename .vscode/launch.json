{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Web: Vite Dev",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "web"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "Web: Chrome (attach Vite)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/web",
      "sourceMaps": true
    },
    {
      "name": "WASM: Node smoke",
      "type": "node",
      "request": "launch",
      "runtimeArgs": ["--experimental-vm-modules"],
      "program": "${workspaceFolder}/emscripten/tools/smoke.mjs",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Web: Vitest",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "test", "--prefix", "web"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
